{
  "name": "paragliding-platform",
  "private": true,
  "workspaces": [
    "apps/customer-web",
    "apps/admin-web",
    "apps/pilot-web",
    "packages/ui",
    "packages/api-client"
  ],
  "scripts": {
    "dev:customer": "npm run dev --workspace @paragliding/customer-web",
    "dev:admin": "npm run dev --workspace @paragliding/admin-web",
    "dev:pilot": "npm run dev --workspace @paragliding/pilot-web",
    "dev:all": "node ./scripts/dev-all.mjs",
    "dev:all:fresh": "node ./scripts/dev-all.mjs --bootstrap",
    "arch:check": "python scripts/check_architecture.py",
    "build:customer": "npm run build --workspace @paragliding/customer-web",
    "build:admin": "npm run build --workspace @paragliding/admin-web",
    "build:pilot": "npm run build --workspace @paragliding/pilot-web"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/leaflet": "^1.9.20",
    "@types/node": "^22.18.10",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "react-icons": "^5.6.0"
  }
}
