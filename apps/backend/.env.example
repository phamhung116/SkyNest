BUSINESS_PHONE=+84 909 000 123
BUSINESS_EMAIL=info@danangparagliding.vn
BUSINESS_ADDRESS=Doi bay Son Tra, Da Nang
NOTIFICATION_PROVIDER=console

PAYMENT_PROVIDER=mockpay
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=
PAYOS_CANCEL_URL=

CUSTOMER_WEB_URL=http://localhost:5173
ACCESS_TOKEN_TTL_HOURS=168
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24

WEATHERAPI_KEY=
WEATHERAPI_LANG=vi
WEATHER_API_CACHE_SECONDS=900

